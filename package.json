{
  "name": "tefa-dex",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "start": "./start.sh",
    "stop": "./stop.sh",
    "status": "./status.sh",
    "attach": "tmux attach -t tefa",
    "deploy": "npx hardhat run scripts/deploy.ts --network localhost",
