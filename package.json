  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.10",
    "@nomicfoundation/hardhat-verify": "^3.0.16",
    "@openzeppelin/contracts": "^4.9.6",
    "@types/node": "^20.0.0",
    "dotenv": "^17.4.2",
    "ethers": "^6.16.0",
    "hardhat": "^3.4.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
